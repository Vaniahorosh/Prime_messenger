<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    android:clipChildren="false"
    tools:context=".ChatListActivity">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewChats"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="32dp"
        android:paddingBottom="120dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:listitem="@layout/item_chat" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/islandHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:id="@+id/islandBlurBackground"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_island_brand"
            android:alpha="1"
            android:outlineProvider="background"
            android:clipToOutline="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivToolbarAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:scaleType="centerCrop"
            android:background="@color/glass_white_10"
            android:src="@drawable/ic_person"
            app:shapeAppearanceOverlay="@style/Rounded15PercentImageView"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:hint="ПОИСК"
            app:boxBackgroundColor="@android:color/transparent"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:hintTextColor="@color/glass_white_30"
            app:layout_constraintBottom_toBottomOf="@+id/ivToolbarAvatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ivToolbarAvatar"
            app:layout_constraintTop_toTopOf="@+id/ivToolbarAvatar">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:maxLength="20"
                android:maxLines="1"
                android:textColor="@color/white"
                android:paddingVertical="10dp"
                android:background="@android:color/transparent" />
        </com.google.android.material.textfield.TextInputLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Индикатор должен быть в самом низу XML и иметь высокую элевацию, чтобы быть поверх всего -->
    <TextView
        android:id="@+id/tvPullIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↓ ПОТЯНИТЕ ВНИЗ ↓"
        android:textColor="@color/prime_background_blue"
        android:alpha="0"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:background="@drawable/bg_glass_card"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:translationY="-100dp"
        android:scaleX="0.5"
        android:scaleY="0.5"
        android:elevation="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

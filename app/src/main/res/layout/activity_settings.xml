<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    tools:context=".SettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:fitsSystemWindows="true"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:contentScrim="@color/prime_background_blue"
            app:statusBarScrim="@color/prime_background_blue"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <ImageView
                android:id="@+id/ivProfilePhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fitsSystemWindows="true"
                android:scaleType="centerCrop"
                android:background="#8E8E93"
                android:src="@drawable/ic_person"
                android:clickable="true"
                android:focusable="true"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7" />

            <View
                android:id="@+id/photoShimmer"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_photo_shimmer"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.8" />

            <!-- Анкер только для измерения "развёрнутой" позиции текста. -->
            <LinearLayout
                android:id="@+id/expandedTitleLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp"
                android:visibility="invisible"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.3">

                <TextView
                    android:id="@+id/tvUserNameExpanded"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="Имя пользователя" />

                <TextView
                    android:id="@+id/tvStatusExpanded"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="в сети"
                    android:textColor="#E6FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Высота тулбара увеличена под компактный круглый аватар -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                app:layout_collapseMode="pin"
                app:contentInsetStart="0dp"
                app:contentInsetStartWithNavigation="0dp">

                <LinearLayout
                    android:id="@+id/collapsedTitleLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="0dp"
                    android:alpha="0">

                    <!-- Анкер только для измерения "свёрнутой" позиции текста -->
                    <LinearLayout
                        android:id="@+id/collapsedTextAnchor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="invisible">

                        <TextView
                            android:id="@+id/tvUserNameCollapsed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/prime_text_teal"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="Имя пользователя" />

                        <TextView
                            android:id="@+id/tvStatusCollapsed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="в прайме"
                            android:textColor="@color/prime_button_teal"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <com.messenger.prime.OverscrollNestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layoutButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipChildren="false"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:weightSum="3"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clipChildren="false">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangePhoto"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginEnd="6dp"
                        android:backgroundTint="@color/prime_background_blue"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="@color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvLabelPhoto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Фото"
                        android:textColor="@color/prime_background_blue"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="@+id/btnChangePhoto"
                        app:layout_constraintStart_toStartOf="@+id/btnChangePhoto"
                        app:layout_constraintTop_toBottomOf="@+id/btnChangePhoto" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clipChildren="false">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExtraSettings"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginHorizontal="3dp"
                        android:backgroundTint="@color/prime_background_blue"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_settings"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="@color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvLabelSettings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Настройки"
                        android:textColor="@color/prime_background_blue"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="@+id/btnExtraSettings"
                        app:layout_constraintStart_toStartOf="@+id/btnExtraSettings"
                        app:layout_constraintTop_toBottomOf="@+id/btnExtraSettings" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clipChildren="false">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogout"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="6dp"
                        android:backgroundTint="#D32F2F"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_exit_to_app"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="@color/white"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvLabelLogout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Выход"
                        android:textColor="#D12F2F"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="@+id/btnLogout"
                        app:layout_constraintStart_toStartOf="@+id/btnLogout"
                        app:layout_constraintTop_toBottomOf="@+id/btnLogout" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAccountData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/layoutButtons">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Логин"
                    android:textColor="#154B86"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="@color/prime_background_blue"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:endIconDrawable="@drawable/ic_edit"
                    app:endIconMode="custom"
                    app:endIconTint="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsLogin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        tools:text="MyLogin123" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="Пароль"
                    android:textColor="#154B86"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="@color/prime_background_blue"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:endIconDrawable="@drawable/ic_edit"
                    app:endIconMode="custom"
                    app:endIconTint="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        tools:text="MySuperPassword" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSettingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="— Настройки —"
                android:textColor="#154B86"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layoutAccountData" />

            <LinearLayout
                android:id="@+id/layoutSwitches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/tvSettingsTitle">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAnimations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:paddingVertical="12dp"
                    android:text="Анимации в приложении"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/prime_background_blue"
                    app:useMaterialThemeColors="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBlocked"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:paddingVertical="12dp"
                    android:text="Показывать заблокированных"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/prime_background_blue"
                    app:useMaterialThemeColors="true" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:paddingVertical="12dp"
                    android:text="Убрать строку поиска"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/prime_background_blue"
                    app:useMaterialThemeColors="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:text="Prime v1.0.0"
                android:textColor="#999999"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layoutSwitches"
                app:layout_constraintVertical_bias="1.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.messenger.prime.OverscrollNestedScrollView>

    <!-- "Летающие" копии имени/статуса. -->
    <TextView
        android:id="@+id/tvUserNameFloating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:clickable="true"
        android:focusable="true"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        tools:text="Имя пользователя" />

    <TextView
        android:id="@+id/tvStatusFloating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="в сети"
        android:textColor="#E6FFFFFF"
        android:textSize="14sp"
        android:singleLine="true"
        android:clickable="false"
        android:focusable="false"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="3" />

    <!-- Контейнер для кастомных диалогов (скрыт по умолчанию) -->
    <FrameLayout
        android:id="@+id/dialogContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="100dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

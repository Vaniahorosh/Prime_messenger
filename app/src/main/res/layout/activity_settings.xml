<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    tools:context=".SettingsActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Синий блок шапки -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerStaticBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/prime_background_blue"
                android:paddingBottom="24dp"
                android:paddingTop="32dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- 1. ВАРИАНТ: С ФОТОГРАФИЕЙ (двухколоночный) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutWithPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:id="@+id/layoutLeftColumn"
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <!-- Назад -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBackWP"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="2dp"
                            android:backgroundTint="@color/white"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_arrow_back"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="@color/prime_background_blue"
                            app:elevation="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Назад"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- Фото -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChangePhoto"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="2dp"
                            android:backgroundTint="@color/white"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_add"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="@color/prime_background_blue"
                            app:elevation="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Фото"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- Выход -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLogout"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="2dp"
                            android:backgroundTint="@color/white"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_exit_to_app"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="#D32F2F"
                            app:elevation="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Выход"
                            android:textColor="#FFCDD2"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- Настройки -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnExtraSettings"
                            style="@style/Widget.MaterialComponents.Button.Icon"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="2dp"
                            android:backgroundTint="@color/white"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/ic_settings"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="28dp"
                            app:iconTint="@color/prime_background_blue"
                            app:elevation="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Настройки"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/photoCard"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginEnd="16dp"
                        app:cardBackgroundColor="#8E8E93"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="8dp"
                        app:layout_constraintBottom_toBottomOf="@+id/layoutLeftColumn"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/layoutLeftColumn"
                        app:layout_constraintTop_toTopOf="@+id/layoutLeftColumn">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/ivProfilePhoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_person"
                                android:clickable="true"
                                android:focusable="true" />
                            <View
                                android:id="@+id/photoShimmer"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_photo_shimmer" />
                            <LinearLayout
                                android:id="@+id/floatingTitleContainer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:orientation="vertical"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="8dp"
                                android:background="#99154B86">
                                <TextView
                                    android:id="@+id/tvUserNameFloating"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/white"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:singleLine="true"
                                    tools:text="дед" />
                                <TextView
                                    android:id="@+id/tvStatusFloating"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="в сети"
                                    android:textColor="#E6FFFFFF"
                                    android:textSize="12sp"
                                    android:singleLine="true" />
                            </LinearLayout>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 2. ВАРИАНТ: БЕЗ ФОТОГРАФИИ (горизонтальный) -->
                <LinearLayout
                    android:id="@+id/layoutNoPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvUserNameStatic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="дед" />

                    <TextView
                        android:id="@+id/tvStatusStatic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="32dp"
                        android:text="в сети"
                        android:textColor="#E6FFFFFF"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Назад -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnBackNP"
                                style="@style/Widget.MaterialComponents.Button.Icon"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:backgroundTint="@color/white"
                                android:padding="0dp"
                                android:insetLeft="0dp"
                                android:insetTop="0dp"
                                android:insetRight="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_arrow_back"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:iconSize="28dp"
                                app:iconTint="@color/prime_background_blue"
                                app:elevation="2dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Назад"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Фото -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnChangePhotoNP"
                                style="@style/Widget.MaterialComponents.Button.Icon"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:backgroundTint="@color/white"
                                android:padding="0dp"
                                android:insetLeft="0dp"
                                android:insetTop="0dp"
                                android:insetRight="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_add"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:iconSize="28dp"
                                app:iconTint="@color/prime_background_blue"
                                app:elevation="2dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Фото"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Выход -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnLogoutNP"
                                style="@style/Widget.MaterialComponents.Button.Icon"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:backgroundTint="@color/white"
                                android:padding="0dp"
                                android:insetLeft="0dp"
                                android:insetTop="0dp"
                                android:insetRight="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_exit_to_app"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:iconSize="28dp"
                                app:iconTint="#D32F2F"
                                app:elevation="2dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Выход"
                                android:textColor="#FFCDD2"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Настройки -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnExtraSettingsNP"
                                style="@style/Widget.MaterialComponents.Button.Icon"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:backgroundTint="@color/white"
                                android:padding="0dp"
                                android:insetLeft="0dp"
                                android:insetTop="0dp"
                                android:insetRight="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="16dp"
                                app:icon="@drawable/ic_settings"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:iconSize="28dp"
                                app:iconTint="@color/prime_background_blue"
                                app:elevation="2dp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Настройки"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Поля ввода данных -->
            <LinearLayout
                android:id="@+id/layoutAccountData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/headerStaticBlock">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Логин"
                    android:textColor="#154B86"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="@color/prime_background_blue"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:endIconDrawable="@drawable/ic_edit"
                    app:endIconMode="custom"
                    app:endIconTint="@color/white">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsLogin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        tools:text="MyLogin123" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="Пароль"
                    android:textColor="#154B86"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundColor="@color/prime_background_blue"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:endIconDrawable="@drawable/ic_edit"
                    app:endIconMode="custom"
                    app:endIconTint="@color/white">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSettingsPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        tools:text="MySuperPassword" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSettingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="— Настройки —"
                android:textColor="#154B86"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layoutAccountData" />

            <LinearLayout
                android:id="@+id/layoutSwitches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/tvSettingsTitle">
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAnimations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:paddingVertical="12dp"
                    android:text="Анимации в приложении"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/prime_background_blue"
                    app:useMaterialThemeColors="true" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBlocked"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:paddingVertical="12dp"
                    android:text="Показывать заблокированных"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/prime_background_blue"
                    app:useMaterialThemeColors="true" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:paddingVertical="12dp"
                    android:text="Убрать строку поиска"
                    android:textColor="#333333"
                    android:textSize="15sp"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/prime_background_blue"
                    app:useMaterialThemeColors="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:text="Prime v1.0.0"
                android:textColor="#999999"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layoutSwitches" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Затемнитель для полноэкранного режима -->
    <View
        android:id="@+id/viewDimmer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:alpha="0"
        android:visibility="gone"
        android:elevation="100dp" />

    <ImageView
        android:id="@+id/ivFullscreenPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:elevation="110dp"
        android:clickable="true"
        android:focusable="true" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseFullPhoto"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:visibility="gone"
        android:padding="0dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:icon="@drawable/ic_arrow_back"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:iconTint="@color/white"
        app:backgroundTint="#80000000"
        app:cornerRadius="20dp"
        app:elevation="120dp" />

    <FrameLayout
        android:id="@+id/dialogContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="200dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
